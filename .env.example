# Smart Toilet Backend Environment Variables
# Copy this to .env and fill in your values

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# For Local Development
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=smart_toilet

# For PlanetScale (Recommended for Cloud)
DB_HOST=your-database.connect.psdb.cloud
DB_PORT=3306
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=smart_toilet

# Alternative: PostgreSQL (AWS RDS, Railway)
# DB_HOST=your-db-instance.c9akciq32.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=smart_toilet

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5000
NODE_ENV=production
API_URL=https://your-app-name.up.railway.app

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-here-must-be-at-least-32-characters-long

# ============================================================
# CORS - Allowed Origins
# ============================================================
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com,http://localhost:3000

# ============================================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================================

# PayPal (for RFID card top-up)
PAYPAL_MODE=sandbox  # Use 'live' for production
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_RETURN_URL=https://your-app-name.up.railway.app/api/payment/paypal/return
PAYPAL_CANCEL_URL=https://your-app-name.up.railway.app/api/payment/paypal/cancel

# Stripe (alternative)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# HARDWARE & RFID CONFIGURATION
# ============================================================
HARDWARE_API_KEY=your-hardware-secret-key-for-esp32
TOILET_COUNT=1

# ============================================================
# EMAIL CONFIGURATION (for notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@your-domain.com

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================================
# TIMEZONE
# ============================================================
TZ=Africa/Kigali
